{
  "name": "ext-suite",
  "version": "0.1.0",
  "private": true,
  "description": "A suite of privacy-focused Chrome MV3 extensions.",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "build:privacy-guard": "npm run build -w @ext-suite/privacy-guard"
  }
}
